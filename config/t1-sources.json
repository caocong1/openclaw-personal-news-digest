{
  "_schema_v": 1,
  "categories": {
    "ai_models": {
      "description": "AI model releases and official announcements",
      "applies_to_subdomains": true,
      "priority": 1,
      "patterns": [
        "openai.com/blog",
        "anthropic.com/blog",
        "blog.google",
        "blogs.microsoft.com",
        "ai.meta.com/blog",
        "deepmind.com/blog",
        "x.ai/blog",
        "mistral.ai/news",
        "ai.google.dev",
        "stability.ai/news",
        "bytedance.com/news",
        "baidu.com/technology",
        "tencent.com/technology",
        "aliyun.com/ai",
        "huawei.com/research"
      ]
    },
    "github_releases": {
      "priority": 1,
      "wildcard_depth": 1,
      "patterns": [
        "github.com/*/releases",
        "github.com/*/releases/latest"
      ]
    },
    "arxiv_papers": {
      "priority": 1,
      "patterns": [
        "arxiv.org/abs",
        "arxiv.org/pdf",
        "arxiv.org/html"
      ]
    },
    "policy_regulation": {
      "priority": 2,
      "patterns": [
        "gov.cn",
        "gov.*",
        "sec.gov",
        "ec.europa.eu",
        "legislation.gov.uk",
        "congress.gov",
        "dpa.org.cn",
        "cac.gov.cn",
        "most.gov.cn",
        "nbsc.gov.cn"
      ]
    },
    "pr_wire": {
      "priority": 2,
      "patterns": [
        "prnewswire.com",
        "businesswire.com",
        "globenewswire.com",
        "prweb.com",
        "business.51cto.com"
      ]
    },
    "scientific": {
      "priority": 2,
      "patterns": [
        "nature.com",
        "science.org",
        "cell.com",
        "nejm.org",
        "jamanetwork.com",
        "lancet.com",
        "pubmed.ncbi.nlm.nih.gov",
        "dx.doi.org"
      ]
    },
    "exchange_filings": {
      "priority": 3,
      "patterns": [
        "sec.gov/filing",
        "disclosure.nl",
        "asx.com.au/regulatory"
      ]
    }
  }
}
